# 서버
PORT=3000
NODE_ENV=development

# DB (DB 팀 제공값으로 교체)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=culturepath

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# 공공데이터 API (실제 키는 .env에만 저장)
TOUR_API_KEY=your_tour_api_key_here
TOUR_API_BASE_URL=https://apis.data.go.kr/B551011/KorService2
RELATED_TOUR_API_BASE_URL=https://apis.data.go.kr/B551011/TarRlteTarService1
RELATED_TOUR_BASE_YM=202503
DATALAB_API_BASE_URL=https://apis.data.go.kr/B551011/DataLabService
PUBLIC_DATA_MOBILE_OS=ETC
PUBLIC_DATA_MOBILE_APP=CulturePath
EXTERNAL_API_TIMEOUT_MS=8000
EXTERNAL_API_MAX_RETRIES=1
EXTERNAL_API_RETRY_DELAY_MS=200

# 장소 캐시 (초 단위)
PLACE_CACHE_ENABLED=true
PLACE_CACHE_TTL_SECONDS=86400
PLACE_CACHE_STALE_MAX_AGE_SECONDS=604800
PLACE_CACHE_DB_FAILURE_COOLDOWN_SECONDS=30

# RAG 서버 (RAG 팀 제공값으로 교체)
RAG_API_URL=http://localhost:8000
