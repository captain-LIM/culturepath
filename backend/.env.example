# 서버
PORT=3000
NODE_ENV=development

# DB (DB 팀 제공값으로 교체)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=culturepath

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# TourAPI (OpenAPI 팀 제공값으로 교체)
TOUR_API_KEY=your_tour_api_key_here

# RAG 서버 (RAG 팀 제공값으로 교체)
RAG_API_URL=http://localhost:8000
